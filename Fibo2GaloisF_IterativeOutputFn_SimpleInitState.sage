    x[41]*x[70],
    x[46]*x[87],
    x[52]*x[110],
    x[55]*x[130],
    x[62]*x[157],
    x[74]*x[183],
    x[87]*x[110]*x[130]*x[157]
]


#-----------Espresso F Galois feedback function----------------------------------------------
# Apply shift_term in a loop
for m in monomials:
    gal_feedback_fn = shift_term(x, f, n, a=a1, b=b1, monomials_to_shift=m)

feedback2add= x[41] * x[70] + x[46] * x[87] + x[52] * x[110] + x[55] * x[130] + x[62] * x[157] + x[74] * x[183] + x[87] * x[110] * x[130] * x[157]
gal_feedback_fn[n-1] = x[0] + x[12] + x[48] + x[115] + x[133] + x[213] + feedback2add
print("\n Espresso F Galois feedback function:\n",gal_feedback_fn)

#---- Generate compensation list-------------------------------
monomial_shifts = [(m, 255, 217) for m in monomials]
all_cm,  C= compute_compensation(monomial_shifts, n, x)
