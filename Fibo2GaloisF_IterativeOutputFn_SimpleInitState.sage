#----------------- Initialize variable -------------------------------
n = 256
V = BooleanPolynomialRing(n, 'x');
x = list(V.gens());

#-----------Fibonacci feedback functions----------------------------------------------
f = [0 for _ in range(n)] 
for i in range(n-1):
    f[i]=x[i+1]
f[n-1]= x[0] + x[12] + x[48] + x[115] + x[133] + x[213]
fibo_feedback_fn=f.copy()
print("\n Y-P Fibonacci feedback function:\n",fibo_feedback_fn)


