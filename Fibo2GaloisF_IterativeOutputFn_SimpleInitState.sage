# Author: Kaushik Sarkar
# Purpose: To convert Y-P Fibinacci to Espresso F Galois

# Output function is iteratively compensated in descending order
# Initial state is simple compensated


import random

print("\n\nOutput function iteratively compensated in descending order")
print("Initial state is simple compensated\n")


##################### User defined functions ###################################


#---------Shifting monomials----------------------
def shift_term(x, f, n, a, b, monomials_to_shift):
    """
    Shift monomials from f[a] to f[b].
    Mapping rule: x_i -> x_{i - a + b} for each variable in the monomial.
    
    Parameters:
        f : list of Boolean polynomials (the vector f)
        a : int, index of source component
        b : int, index of target component
        monomials_to_shift : single monomial or list of monomials
    """
    # Ensure we have a list
    if not isinstance(monomials_to_shift, list):  # check if input is a list or not
        monomials_to_shift = [monomials_to_shift]  # if not, convert to a list
    
    for monomial in monomials_to_shift:
        # 1. Remove monomial from f[a]
        f[a] = sum(m for m in f[a].monomials() if m != monomial)
        
        # 2. Compute shifted monomial
        new_m = 1
        for var in monomial.variables():
            i = int(str(var)[1:])      # Ex. get index 3 from "x3"
            j = (i - a + b) % n              # shifted index
            new_m *= x[j]
        
        # 3. Add shifted monomial to f[b]
        f[b] = f[b] + new_m
    
    return f


#----------------- Compensation list ------------------
def compute_compensation(monomial_shifts, n, x):
    """
    Compute compensation lists for each monomial separately,
    and also the combined result.
    """
    all_cm = []   # list of individual compensation lists
    
    # process each monomial separately
    for monomial, a, b in monomial_shifts:
        cm = [0 for _ in range(n)]
        for i in range(b+1, a+1):
            k = i - a - 1
            new_m = 1
            for var in monomial.variables():
                j = int(str(var)[1:])
                new_m *= x[j + k]
            cm[i] = new_m
        all_cm.append(cm)
    
    # sum all cm’s to get final C
    C = [sum(cm[i] for cm in all_cm) for i in range(n)]
    
    return all_cm, C


# -------Iterative compensation for output function-------
def apply_compensation_iterative(fz, order, C, x):
    cur = fz
    # descending order
    for idx in reversed(order):
        # compensate ONLY current variable
        cur = cur.subs({
            x[idx]: x[idx] + C[idx]
        })
        
    return cur


# --------Simple compensation for initial state---------
def initialValue_simple_compensate(X_initial, C, x):
    """
    Normal (non-iterative) compensation:
    X_hat[i] = X[i] + c_i(X)
    evaluated only on original state.
    """
    n = len(X_initial)
    subs_map = {x[j]: X_initial[j] for j in range(n)}
    X_hat = []
    for i in range(n):
        ci_val = int(C[i].subs(subs_map))
        X_hat.append((X_initial[i] + ci_val) % 2)

    return X_hat


# ---------To collect information of the output function-----------
def getInfo(myFunc):
    vars_in_myFunc = set()
    monomials = myFunc.monomials()
    num_monomials = len(monomials)
    deg = myFunc.degree()

    # find all variables used
    for monomial in monomials:
        vars_in_myFunc.update(monomial.variables())
    
    num_vars = len(vars_in_myFunc)

    # find monomials having maximum degree
    max_deg_monomials = [m for m in monomials if m.degree() == deg]

    return num_vars, deg, num_monomials, max_deg_monomials


#------------------ NLFSR STEP ---------------------------------------------
def cipher_step(X, f, z, x):
    subs_map = {x[i]: X[i] for i in range(len(X))}
    out_val = int(z.subs(subs_map))           # output
    new_state = [int(fi.subs(subs_map)) for fi in f]  # next state
    return out_val, new_state




