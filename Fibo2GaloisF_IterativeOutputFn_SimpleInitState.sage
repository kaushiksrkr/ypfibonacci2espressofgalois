# --------Extract indices to set the order of compensation-------
indices = set()
for monomial in fz_fibo.monomials():
    for var in monomial.variables():
        name = str(var)  # e.g., "x80"
        idx = int(name[1:])  # extract number after "x", i.e. 80
        indices.add(idx)

order = sorted(indices)

#-------Compensate Y-P Fibonacci output function iteratively in descending order to get Galois output function --------------
fz_gal = apply_compensation_iterative(fz_fibo, order, C, x)

#print("\nY-P Fibonacci output function:\n", fz_fibo)
#print("\n\n Galois output function (after iterative compensation in descending order):\n", fz_gal)


#----- To get the information of the output functions---------------

num_vars,deg,num_monomials,max_deg_monomials=getInfo(fz_fibo)
print('\nInformation of Y-P Fibonacci output function:\n# of variables: {}\n# of monomials:{}\nAlgebraic degree: {}\nMax_deg_monomials: \nß{}'.format(num_vars,num_monomials,deg,max_deg_monomials))

num_vars,deg,num_monomials,max_deg_monomials=getInfo(fz_gal)
print('\nInformation of Espresso F Galois output function:\n# of variables: {}\n# of monomials: {}\nAlgebraic degree: {}\nMax_deg_monomials: \n{}'.format(num_vars,num_monomials,deg,max_deg_monomials))


#--------------Random initial state-------------------------------------------------------
X_initial = [random.randint(0,1) for _ in range(n)]   # corresponds to x0,x1,x2,x3,....x255

# -------Apply simple compensation to initial state --------------
Xhat = initialValue_simple_compensate(X_initial, C, x)

print("\nRandom initial state (for Y-P Fibonacci) :\n", X_initial)
print("\nSimple compensated initial state (for Espresso F Galois):\n", Xhat)



#---------------------Running Y-P Fibonacci  ------------------------------------------
# Initialize initial state
X = X_initial

# Output function
z=fz_fibo

# Fibonacci feedback function
f=fibo_feedback_fn

outputs_fib = []
for _ in range(256):
    out, X = cipher_step(X, f, z, x)
    outputs_fib.append(out)

print("\n\nOutput sequence (Y-P Fibonacci):\n", outputs_fib)


#------------------Running Espresso F Galois -------------------------------------------------------------------
# Compensated initial state 
X = Xhat

# Output function
z = fz_gal

# Feedback functions
f = gal_feedback_fn

# Example: generate 256 bits
outputs_gal = []
for _ in range(256):
    out, X = cipher_step(X, f, z, x)
    outputs_gal.append(out)


print("\nOutput sequence (Espresso F Galois):\n", outputs_gal)

print("\nY-P Fibonacci output sequence= Espresso F Galois output sequence? ",outputs_fib==outputs_gal)
print("\n\n")
